#------------------------------------------------------------------------------------------------
# 10.5) Uninstaller — App Catalog & Deep Clean
#------------------------------------------------------------------------------------------------

# Patterns excluded from the uninstall list (system components, runtimes, drivers, updates)
$Script:UninstallExcludePatterns = @(
    "^Microsoft Visual C\+\+",
    "Microsoft \.NET",
    "\.NET Runtime",
    "\.NET Desktop Runtime",
    "ASP\.NET Core",
    "Windows SDK",
    "Windows Driver",
    "Windows Update",
    "Security Update for",
    "Update for Windows",
    "Hotfix for",
    "KB\d{6,7}",
    "^DirectX",
    "MSXML \d",
    "^WMI ",
    "Microsoft Application Error Reporting",
    "Microsoft Web Deploy",
    "Microsoft Report Viewer",
    "Microsoft MPI",
    "Microsoft Policy Platform",
    "Microsoft Primary Interop",
    "Microsoft SQL Server \d{4} .*(Native|Express|Compact)",
    "Intel.*Driver",
    "Intel.*Software",
    "Realtek.*Driver",
    "AMD.*Driver",
    "NVIDIA.*Driver",
    "Dell Update",
    "Dell Command",
    "Dell SupportAssist OS Recovery",
    "Bonjour",
    "Apple Software Update",
    "VMware Tools",
    "VirtualBox Guest Additions"
)

$Script:AllInstalledApps = @()
$Script:UninstDiag     = @{}

function Get-InstalledApps {
    # Use Get-ChildItem to enumerate subkeys, then Get-ItemProperty -LiteralPath per key.
    # Get-ItemProperty with a wildcard path returns PSObjects where missing registry values
    # throw on property access under Set-StrictMode -Version Latest, aborting entire hives.
    # The per-key approach isolates every entry so one bad key never kills the scan.
    $hivePaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall",
        "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"
    )

    $seen    = @{}
    $results = New-Object System.Collections.Generic.List[object]
    $Script:UninstDiag = @{ HiveCounts = @{}; Added = 0; Skipped = 0 }

    foreach ($hivePath in $hivePaths) {
        $hiveLabel = if ($hivePath -match 'WOW6432') { 'HKLM-32' } elseif ($hivePath -match 'HKCU') { 'HKCU' } else { 'HKLM-64' }

        if (-not (Test-Path -LiteralPath $hivePath -ErrorAction SilentlyContinue)) {
            $Script:UninstDiag.HiveCounts[$hiveLabel] = 'path not found'
            continue
        }

        $subkeys = $null
        try { $subkeys = @(Get-ChildItem -LiteralPath $hivePath -ErrorAction SilentlyContinue) } catch { $Script:UninstDiag.HiveCounts[$hiveLabel] = "enum error: $($_.Exception.Message)"; continue }
        if (-not $subkeys -or $subkeys.Count -eq 0) { $Script:UninstDiag.HiveCounts[$hiveLabel] = '0 subkeys'; continue }

        $hiveAdded = 0; $hiveSkipped = 0

        foreach ($subkey in $subkeys) {
            try {
                $props = $null
                try { $props = Get-ItemProperty -LiteralPath $subkey.PSPath -ErrorAction SilentlyContinue } catch { $hiveSkipped++; continue }
                if ($null -eq $props) { $hiveSkipped++; continue }

                # DisplayName — required
                $displayName = $null
                try { $displayName = $props.DisplayName } catch { }
                if ($null -eq $displayName -or $displayName.ToString().Trim() -eq '') { $hiveSkipped++; continue }
                $displayName = $displayName.ToString().Trim()

                # UninstallString — required
                $uninstallString = $null
                try { $uninstallString = $props.UninstallString } catch { }
                if ($null -eq $uninstallString -or $uninstallString.ToString().Trim() -eq '') { $hiveSkipped++; continue }
                $uninstallString = $uninstallString.ToString().Trim()

                # SystemComponent = 1 → OS component, skip
                $sysComp = 0
                try { if ($null -ne $props.SystemComponent) { $sysComp = [int]$props.SystemComponent } } catch { }
                if ($sysComp -eq 1) { $hiveSkipped++; continue }

                # ReleaseType update/hotfix → skip
                $releaseType = ''
                try { if ($null -ne $props.ReleaseType) { $releaseType = $props.ReleaseType.ToString() } } catch { }
                if ($releaseType -match 'Update|Hotfix|Security') { $hiveSkipped++; continue }

                # Name itself looks like a KB / update entry → skip
                if ($displayName -match '^(KB\d|Security Update|Hotfix|Update for |Service Pack)') { $hiveSkipped++; continue }

                # Dedup
                $dedupeKey = $displayName.ToLower()
                if ($seen.ContainsKey($dedupeKey)) { $hiveSkipped++; continue }

                # Exclusion pattern list
                $excluded = $false
                foreach ($pat in $Script:UninstallExcludePatterns) {
                    try { if ($displayName -match $pat) { $excluded = $true; break } } catch { }
                }
                if ($excluded) { $hiveSkipped++; continue }

                $seen[$dedupeKey] = $true

                # Optional fields
                $publisher = '';       try { if ($null -ne $props.Publisher)           { $publisher       = $props.Publisher.ToString().Trim()           } } catch { }
                $version   = '';       try { if ($null -ne $props.DisplayVersion)      { $version         = $props.DisplayVersion.ToString().Trim()      } } catch { }
                $quietUn   = '';       try { if ($null -ne $props.QuietUninstallString){ $quietUn          = $props.QuietUninstallString.ToString().Trim() } } catch { }
                $instLoc   = '';       try { if ($null -ne $props.InstallLocation)     { $instLoc         = $props.InstallLocation.ToString().Trim()     } } catch { }

                $sizeKB = 0; try { if ($null -ne $props.EstimatedSize) { $sizeKB = [int]$props.EstimatedSize } } catch { }
                $sizeStr = if ($sizeKB -ge 1048576) { "$([math]::Round($sizeKB/1048576,1)) GB" }
                           elseif ($sizeKB -ge 1024)  { "$([math]::Round($sizeKB/1024,0)) MB"  }
                           elseif ($sizeKB -gt 0)      { "$sizeKB KB" }
                           else                         { "" }

                $installDate = ''
                try {
                    if ($null -ne $props.InstallDate) {
                        $rawDate = $props.InstallDate.ToString().Trim()
                        if ($rawDate -match '^\d{8}$') { $installDate = [datetime]::ParseExact($rawDate,'yyyyMMdd',$null).ToString('MM/dd/yyyy') }
                    }
                } catch { }

                $results.Add([pscustomobject]@{
                    DisplayName     = $displayName
                    Publisher       = $publisher
                    Version         = $version
                    InstallDate     = $installDate
                    SizeStr         = $sizeStr
                    SizeKB          = $sizeKB
                    UninstallString = $uninstallString
                    QuietUninstall  = $quietUn
                    InstallLocation = $instLoc
                })
                $hiveAdded++

            } catch { $hiveSkipped++ }
        }

        $Script:UninstDiag.HiveCounts[$hiveLabel] = "added=$hiveAdded skipped=$hiveSkipped (of $($subkeys.Count))"
        $Script:UninstDiag.Added   += $hiveAdded
        $Script:UninstDiag.Skipped += $hiveSkipped
    }

    return $results | Sort-Object DisplayName
}

function Get-UninstallMode {
    # Returns 'Silent' if we can run without any UI, 'Interactive' otherwise.
    # Silent = has an explicit QuietUninstallString, OR is MSI-based (we inject /qn).
    param([Parameter(Mandatory=$true)][pscustomobject]$App)
    if (-not [string]::IsNullOrWhiteSpace($App.QuietUninstall)) { return 'Silent' }
    $us = $App.UninstallString
    if ($us -match 'msiexec' -or $us -match '\{[0-9A-Fa-f\-]{36}\}') { return 'Silent' }
    return 'Interactive'
}

function Build-SilentArgs {
    # Given an app's uninstall string, return @{ Exe=...; Args=... } ready for silent launch.
    param([Parameter(Mandatory=$true)][pscustomobject]$App)
    # Prefer explicit quiet string
    $rawCmd = if (-not [string]::IsNullOrWhiteSpace($App.QuietUninstall)) { $App.QuietUninstall }
              else { $App.UninstallString }
    $exe = ''; $argStr = ''
    if ($rawCmd -match '^"([^"]+)"(.*)$')           { $exe = $matches[1].Trim(); $argStr = $matches[2].Trim() }
    elseif ($rawCmd -match '^([^\s"]+\.exe)\s*(.*)$') { $exe = $matches[1].Trim(); $argStr = $matches[2].Trim() }
    else                                               { $exe = $rawCmd.Trim() }

    # Inject MSI quiet flags if this is an msiexec call without them
    if ([string]::IsNullOrWhiteSpace($App.QuietUninstall)) {
        $isMsi = ($exe -match 'msiexec' -or $argStr -match '\{[0-9A-Fa-f\-]{36}\}')
        if ($isMsi -and $argStr -notmatch '/q|/quiet|/passive|/qn') {
            $argStr = ($argStr -replace '/I\s*(\{)', '/X $1').Trim()
            $argStr = "$argStr /qn /norestart".Trim()
        }
    }
    return @{ Exe = $exe; Args = $argStr }
}

function Build-InteractiveArgs {
    param([Parameter(Mandatory=$true)][pscustomobject]$App)
    $rawCmd = $App.UninstallString
    $exe = ''; $argStr = ''
    if ($rawCmd -match '^"([^"]+)"(.*)$')           { $exe = $matches[1].Trim(); $argStr = $matches[2].Trim() }
    elseif ($rawCmd -match '^([^\s"]+\.exe)\s*(.*)$') { $exe = $matches[1].Trim(); $argStr = $matches[2].Trim() }
    else                                               { $exe = $rawCmd.Trim() }
    return @{ Exe = $exe; Args = $argStr }
}

function Start-UninstallProcess {
    # Launches the uninstaller process and returns the Process object (non-blocking).
    param(
        [Parameter(Mandatory=$true)][pscustomobject]$App,
        [Parameter(Mandatory=$true)][bool]$Silent,
        [Parameter(Mandatory=$true)][System.Windows.Forms.RichTextBox]$OutputBox,
        [Parameter(Mandatory=$true)][System.Windows.Forms.ToolStripStatusLabel]$StatusLabel
    )
    $parsed = if ($Silent) { Build-SilentArgs -App $App } else { Build-InteractiveArgs -App $App }
    $exe    = $parsed.Exe
    $argStr = $parsed.Args

    if ([string]::IsNullOrWhiteSpace($exe)) {
        Write-Log -Message "  ERROR: Cannot parse uninstall string for $($App.DisplayName)" -OutputBox $OutputBox -Color $Script:Colors.Danger -StatusLabel $StatusLabel
        return $null
    }

    $modeLabel = if ($Silent) { 'silent' } else { 'interactive' }
    Write-Log -Message "==> [$modeLabel] $($App.DisplayName)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel
    Write-Log -Message "    $exe $argStr".TrimEnd() -OutputBox $OutputBox -Color $Script:Colors.TextMuted -StatusLabel $StatusLabel

    try {
        $psi = New-Object System.Diagnostics.ProcessStartInfo
        $psi.FileName    = $exe
        $psi.Arguments   = $argStr
        if ($Silent) {
            # Silent: capture output, no window
            $psi.UseShellExecute        = $false
            $psi.CreateNoWindow         = $true
            $psi.RedirectStandardOutput = $true
            $psi.RedirectStandardError  = $true
        } else {
            # Interactive: let the installer draw its own UI
            $psi.UseShellExecute = $true
        }
        return [System.Diagnostics.Process]::Start($psi)
    } catch {
        Write-Log -Message "  ERROR starting process: $($_.Exception.Message)" -OutputBox $OutputBox -Color $Script:Colors.Danger -StatusLabel $StatusLabel
        return $null
    }
}

function Invoke-DeepClean {
    param(
        [Parameter(Mandatory=$true)][pscustomobject]$App,
        [Parameter(Mandatory=$true)][System.Windows.Forms.RichTextBox]$OutputBox,
        [Parameter(Mandatory=$true)][System.Windows.Forms.ToolStripStatusLabel]$StatusLabel
    )
    Write-Log -Message "  [Deep Clean] $($App.DisplayName)" -OutputBox $OutputBox -Color $Script:Colors.BlueAccent -StatusLabel $StatusLabel

    # Build search terms from app name + publisher
    $searchTerms = @()
    $cleanName   = $App.DisplayName -replace '\s+\d[\d\.\s]*$','' -replace '\s+(x86|x64|32.bit|64.bit)$','' `
                                    -replace '[^a-zA-Z0-9\s]',''  -replace '\s+',' '
    $nameWords = @($cleanName.Trim() -split ' ' | Where-Object { $_.Length -gt 3 })
    if ($nameWords.Count -gt 0) { $searchTerms += $nameWords[0] }
    if ($App.Publisher -and $App.Publisher.Trim().Length -gt 3) {
        $pubWords = @($App.Publisher.Trim() -split '\s+' | Where-Object { $_.Length -gt 3 })
        if ($pubWords.Count -gt 0 -and ($searchTerms -notcontains $pubWords[0])) { $searchTerms += $pubWords[0] }
    }
    if ($searchTerms.Count -eq 0) {
        Write-Log -Message "  No usable search terms — skipping deep clean." -OutputBox $OutputBox -Color $Script:Colors.TextMuted -StatusLabel $StatusLabel
        return
    }

    $removed = 0

    # 1. Explicit InstallLocation
    if (-not [string]::IsNullOrWhiteSpace($App.InstallLocation)) {
        $loc = $App.InstallLocation.TrimEnd('\').Trim()
        if ($loc.Length -gt 5 -and (Test-Path -LiteralPath $loc)) {
            Write-Log -Message "  Leftover install dir: $loc" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel
            try { Remove-Item -LiteralPath $loc -Recurse -Force -ErrorAction Stop; $removed++
                  Write-Log -Message "  Removed: $loc" -OutputBox $OutputBox -Color $Script:Colors.Success -StatusLabel $StatusLabel }
            catch { Write-Log -Message "  Could not remove (in use?): $loc" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel }
        }
    }

    # 2. File system scan
    $fsScanRoots = @(
        $env:APPDATA, $env:LOCALAPPDATA, $env:ProgramData,
        $env:ProgramFiles, ${env:ProgramFiles(x86)},
        (Join-Path $env:LOCALAPPDATA "Programs"),
        (Join-Path $env:ProgramData  "Microsoft\Windows\Start Menu\Programs")
    )
    foreach ($root in $fsScanRoots | Where-Object { $_ -and (Test-Path -LiteralPath $_) }) {
        foreach ($term in $searchTerms) {
            try {
                $hits = @(Get-ChildItem -Path $root -Directory -ErrorAction SilentlyContinue | Where-Object { $_.Name -like "*$term*" })
                foreach ($h in $hits) {
                    Write-Log -Message "  Leftover folder: $($h.FullName)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel
                    try { Remove-Item -LiteralPath $h.FullName -Recurse -Force -ErrorAction Stop; $removed++
                          Write-Log -Message "  Removed: $($h.FullName)" -OutputBox $OutputBox -Color $Script:Colors.Success -StatusLabel $StatusLabel }
                    catch { Write-Log -Message "  Could not remove: $($h.FullName)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel }
                }
            } catch { }
        }
    }

    # 3. Registry scan — skip known safe system paths
    $regScanRoots = @("HKLM:\SOFTWARE","HKLM:\SOFTWARE\WOW6432Node","HKCU:\SOFTWARE","HKCU:\SOFTWARE\Classes")
    foreach ($regRoot in $regScanRoots) {
        foreach ($term in $searchTerms) {
            try {
                $keys = @(Get-ChildItem -Path $regRoot -ErrorAction SilentlyContinue | Where-Object { $_.PSChildName -like "*$term*" })
                foreach ($key in $keys) {
                    if ($key.PSPath -match '\\(Microsoft\\Windows|Classes\\CLSID|Classes\\Interface|Classes\\TypeLib)\\') { continue }
                    Write-Log -Message "  Leftover reg key: $($key.PSPath)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel
                    try { Remove-Item -LiteralPath $key.PSPath -Recurse -Force -ErrorAction Stop; $removed++
                          Write-Log -Message "  Removed: $($key.PSPath)" -OutputBox $OutputBox -Color $Script:Colors.Success -StatusLabel $StatusLabel }
                    catch { Write-Log -Message "  Could not remove: $($key.PSPath)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel }
                }
            } catch { }
        }
    }

    if ($removed -eq 0) { Write-Log -Message "  No leftovers found." -OutputBox $OutputBox -Color $Script:Colors.TextMuted -StatusLabel $StatusLabel }
    else { Write-Log -Message "  Deep clean: $removed item(s) removed." -OutputBox $OutputBox -Color $Script:Colors.Success -StatusLabel $StatusLabel }
}


