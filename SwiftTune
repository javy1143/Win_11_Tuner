        foreach ($s in $serviceToggles) {
            if ($Script:ServiceSafelist -contains $s.Name) { continue }
            $info = Get-ServiceStartupInfo -Name $s.Name
            if (-not $info.Exists) { continue }
            $total++
            if ($info.StartupType -eq $s.Startup) { $match++ }
        }
        if ($total -eq 0) { "NotAvailable" } elseif ($match -eq 0) { "NotApplied" } elseif ($match -eq $total) { "Applied" } else { "Partial" }
