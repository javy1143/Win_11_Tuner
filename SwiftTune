# Tweak tab events
$btnSelectAll.Add_Click({
    foreach ($cb in $Script:CheckBoxes.Values) { if ($cb.Enabled) { $cb.Checked = $true } }
})
$btnDeselectAll.Add_Click({
    foreach ($cb in $Script:CheckBoxes.Values) { $cb.Checked = $false }
})
$btnRecommended.Add_Click({
    $heavyMaint = @("maint_dism_restorehealth","maint_sfc_scannow","maint_onedrive_health","maint_dism_cleanup","maint_driver_diag")
    foreach ($t in $Script:Tweaks) {
        $cb = $Script:CheckBoxes[$t.Id]
        if (-not $cb -or -not $cb.Enabled) { if ($cb) { $cb.Checked = $false }; continue }
        $isRecommended = $false
        if ($t.Risk -ne "High" -and $t.Category -ne "Maintenance") { $isRecommended = $true }
        if ($t.Category -eq "Maintenance" -and $t.Risk -eq "Low" -and ($heavyMaint -notcontains $t.Id)) { $isRecommended = $true }
        $cb.Checked = $isRecommended
    }
})
$btnRefresh.Add_Click({ Refresh-TweakStates })
$btnCancel.Add_Click({
    if ($Script:ApplyRun) { $Script:ApplyRun.CancelRequested = $true; $btnCancel.Enabled = $false; $statusLabel.Text = "Cancelling..." }
})
$btnExportLog.Add_Click({
    $dlg = New-Object System.Windows.Forms.SaveFileDialog
    $dlg.Title    = "Export Log"
    $dlg.Filter   = "Text files (*.txt)|*.txt|All files (*.*)|*.*"
    $dlg.FileName = "SwiftTune_Log_$(Get-Date -Format 'yyyyMMdd_HHmmss').txt"
    if ($dlg.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) {
        try {
            $outputBox.Text | Set-Content -Path $dlg.FileName -Encoding UTF8
            [System.Windows.Forms.MessageBox]::Show("Log exported to:`r`n$($dlg.FileName)","Export Log","OK","Information") | Out-Null
        } catch {
            [System.Windows.Forms.MessageBox]::Show("Failed to export log: $($_.Exception.Message)","Export Log","OK","Error") | Out-Null
        }
    }
})

$btnApply.Add_Click({
    if ($Script:ApplyRun) { return }
    $selected = @()
    foreach ($kv in $Script:CheckBoxes.GetEnumerator()) {
        if ($kv.Value.Checked -and $kv.Value.Enabled) { $selected += $kv.Key }
    }
    if ($selected.Count -eq 0) {
        [System.Windows.Forms.MessageBox]::Show("Select at least one tweak to apply.","Nothing Selected","OK","Information") | Out-Null
        return
    }
    $high = @($Script:Tweaks | Where-Object { ($selected -contains $_.Id) -and ($_.Risk -eq "High") })
    if ($high.Count -gt 0) {
        $msg = "You selected High risk tweaks:`r`n`r`n" + ($high | ForEach-Object { "- $($_.Name)" } | Out-String) + "`r`nContinue?"
        $r = [System.Windows.Forms.MessageBox]::Show($msg,"Confirm High Risk","YesNo","Warning")
        if ($r -ne [System.Windows.Forms.DialogResult]::Yes) { return }
    }
    $destructive = @($Script:Tweaks | Where-Object { ($selected -contains $_.Id) -and ($_.Id -eq "maint_dism_cleanup") })
    if ($destructive.Count -gt 0) {
        $r2 = [System.Windows.Forms.MessageBox]::Show(
            "DISM StartComponentCleanup is selected.`r`n`r`nThis PERMANENTLY removes the ability to roll back to your previous Windows version.`r`n`r`nOnly proceed if Windows 25H2 has been stable for at least a week.`r`n`r`nAre you sure?",
            "Confirm Destructive Action","YesNo","Warning")
        if ($r2 -ne [System.Windows.Forms.DialogResult]::Yes) { return }
    }
    Start-ApplyRun -SelectedIds $selected -CreateRestorePoint ([bool]$cbRestorePoint.Checked)
})

$btnUndoLast.Add_Click({
    $p = Load-LastBackupPath
    if (-not $p) { [System.Windows.Forms.MessageBox]::Show("No last-run backup manifest found.","Undo Last Run","OK","Information") | Out-Null; return }
    $ans = [System.Windows.Forms.MessageBox]::Show("This will restore settings captured in:`r`n$p`r`n`r`nProceed?","Undo Last Run","YesNo","Warning")
    if ($ans -ne "Yes") { return }
    try { Restore-FromManifest -ManifestPath $p -OutputBox $outputBox -StatusLabel $statusLabel; Refresh-TweakStates }
    catch { Write-Log -Message "ERROR: Restore failed -> $($_.Exception.Message)" -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel }
})

# Uninstaller tab events
$btnUninstRefresh.Add_Click({ Refresh-UninstallList })

$txtSearch.Add_TextChanged({
    if ($Script:AllInstalledApps.Count -gt 0) { Populate-UninstallList -Filter $txtSearch.Text }
})

$btnUninstSelectAll.Add_Click({
    foreach ($item in $uninstListView.Items) { $item.Checked = $true }
})

$btnUninstDeselectAll.Add_Click({
    foreach ($item in $uninstListView.Items) { $item.Checked = $false }
})

$uninstListView.Add_ItemChecked({
    $checked = @($uninstListView.CheckedItems).Count
    $lblSelectedCount.Text = "$checked selected"
})

$btnUninstallSelected.Add_Click({
    if ($Script:UninstallRun) { return }
    $appsToRemove = @()
    foreach ($item in $uninstListView.CheckedItems) {
        if ($item.Tag) { $appsToRemove += $item.Tag }
    }
    if ($appsToRemove.Count -eq 0) {
        [System.Windows.Forms.MessageBox]::Show("Check at least one application to uninstall.","Nothing Selected","OK","Information") | Out-Null
        return
    }

    $nameList = ($appsToRemove | ForEach-Object { "  - $($_.DisplayName)" }) -join "`r`n"
    $deepStr  = if ($cbDeepClean.Checked) { "`r`n`r`nDeep Clean is enabled: leftover files and registry keys will also be removed." } else { "" }
    $msg = "The following $($appsToRemove.Count) application(s) will be uninstalled:`r`n`r`n$nameList$deepStr`r`n`r`nProceed?"
    $r = [System.Windows.Forms.MessageBox]::Show($msg,"Confirm Uninstall","YesNo","Warning")
    if ($r -ne [System.Windows.Forms.DialogResult]::Yes) { return }

    Start-UninstallRun -AppsToRemove $appsToRemove -DeepClean ([bool]$cbDeepClean.Checked)
})

# Load uninstaller list when its tab is first selected
$tabs.Add_SelectedIndexChanged({
    if ($tabs.SelectedTab -eq $tabUninstaller -and $Script:AllInstalledApps.Count -eq 0) {
        Refresh-UninstallList
    }
})

$mainForm.Add_Shown({
    Write-Log -Message "$($Script:AppName) v$($Script:AppVersion) ready." -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
    Write-Log -Message "Backups: $Script:BackupRoot" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
    Write-Log -Message "Session log: $Script:SessionLog" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel

    try {
        $cs = Get-CimInstance -ClassName Win32_ComputerSystem
        $domainInfo = if ($cs.PartOfDomain) { "Domain: $($cs.Domain)" } else { "Workgroup: $($cs.Workgroup)" }
        Write-Log -Message "Machine: $($cs.Name) | $domainInfo | RAM: $([math]::Round($cs.TotalPhysicalMemory/1GB,1)) GB" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel

        if ($cs.PartOfDomain) {
            Write-Log -Message "NOTE: Domain-joined machine. 'Disable VBS' is blocked here by design." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
            Write-Log -Message "      To disable VBS/HVCI via GPO: Computer Config > Admin Templates > System > Device Guard > Turn On VBS = Disabled." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
        }
    } catch { }

    $freeGB = Get-DriveFreeGB
    if ($null -ne $freeGB) { Write-Log -Message "C: drive free space: $freeGB GB" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel }

    $vbsCb = $Script:CheckBoxes["perf_vbs_disable"]
    if ($vbsCb -and -not $vbsCb.Enabled) {
        Write-Log -Message "NOTE: 'Disable VBS' is unavailable on this machine (domain-joined or Intune-enrolled)." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
    }

    Refresh-TweakStates
})

