# 13) Apply Engine (UI Timer)
#------------------------------------------------------------------------------------------------
$Script:ApplyRun = $null
$applyTimer = New-Object System.Windows.Forms.Timer
$applyTimer.Interval = 50

function Set-UiRunningState {
    param([bool]$IsRunning)
    $btnApply.Enabled             = -not $IsRunning
    $btnCancel.Enabled            = $IsRunning
    $btnSelectAll.Enabled         = -not $IsRunning
    $btnDeselectAll.Enabled       = -not $IsRunning
    $btnRecommended.Enabled       = -not $IsRunning
    $btnRefresh.Enabled           = -not $IsRunning
    $btnUndoLast.Enabled          = -not $IsRunning
    $btnExportLog.Enabled         = -not $IsRunning
    $cbRestorePoint.Enabled       = -not $IsRunning
    $btnUninstallSelected.Enabled = -not $IsRunning
    $btnUninstRefresh.Enabled     = -not $IsRunning
}

function Start-ApplyRun {
    param([Parameter(Mandatory=$true)][string[]]$SelectedIds,[Parameter(Mandatory=$true)][bool]$CreateRestorePoint)
    $Script:ApplyRun = [pscustomobject]@{
        SelectedIds     = $SelectedIds
        Queue           = New-Object System.Collections.Generic.Queue[string]
        Total           = [Math]::Max(1,$SelectedIds.Count)
        Index           = 0
        BackupCtx       = (New-BackupContext)
        CreateRestore   = $CreateRestorePoint
        RestoreDone     = $false
        CancelRequested = $false
        HadErrors       = $false
        ManifestPath    = $null
    }
    foreach ($id in $SelectedIds) { [void]$Script:ApplyRun.Queue.Enqueue($id) }
    Set-UiRunningState -IsRunning $true
    $progress.Value = 0
    $statusLabel.Text = "Starting..."
    Write-Log -Message ("Starting apply run. Selected tweaks: {0}" -f ($SelectedIds -join ", ")) -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
    $applyTimer.Start()
}

function Complete-ApplyRun {
    param([ValidateSet("Complete","Cancelled","Error")][string]$Outcome,[string]$ErrorMessage=$null)
    $applyTimer.Stop()
    Set-UiRunningState -IsRunning $false
    if ($Outcome -eq "Cancelled") {
        Write-Log -Message "Operation cancelled by user." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
        $statusLabel.Text = "Cancelled"
    } elseif ($Outcome -eq "Error") {
        Write-Log -Message ("Worker error: {0}" -f $ErrorMessage) -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel
        $statusLabel.Text = "Error"
    } else {
        $manifestPath = [string]$Script:ApplyRun.ManifestPath
        if ([string]::IsNullOrWhiteSpace($manifestPath)) {
            Write-Log -Message "Operations complete. Backup manifest was not saved." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
        } else {
            Write-Log -Message "Backup manifest saved: $manifestPath" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
            if ($Script:ApplyRun.HadErrors) {
                Write-Log -Message "Operations complete. Some items may have failed — review the log." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
            } else {
                Write-Log -Message "All selected operations completed successfully." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
            }
        }
        $statusLabel.Text = "Complete"
        Refresh-TweakStates
    }
    $progress.Value = 0
    $Script:ApplyRun = $null
}

$applyTimer.Add_Tick({
    try {
        if (-not $Script:ApplyRun) { $applyTimer.Stop(); return }
        if ($Script:ApplyRun.CancelRequested) { Complete-ApplyRun -Outcome "Cancelled"; return }

        if ($Script:ApplyRun.CreateRestore -and -not $Script:ApplyRun.RestoreDone) {
            $statusLabel.Text = "Working: Restore point"
            try {
                Write-Log -Message "Attempting to create System Restore Point..." -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
                Checkpoint-Computer -Description ("$($Script:AppName) {0}" -f (Get-Date -Format "yyyy-MM-dd HH:mm:ss")) -RestorePointType "MODIFY_SETTINGS" | Out-Null
                Write-Log -Message "Restore point created." -OutputBox $outputBox -Color $Script:Colors.Success -StatusLabel $statusLabel
            } catch { Write-Log -Message ("Restore point failed: {0}" -f $_.Exception.Message) -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel }
            finally { $Script:ApplyRun.RestoreDone = $true }
            return
        }

        if ($Script:ApplyRun.Queue.Count -eq 0) {
            try { $Script:ApplyRun.ManifestPath = Save-BackupManifest -BackupCtx $Script:ApplyRun.BackupCtx -SelectedTweakIds $Script:ApplyRun.SelectedIds }
            catch { $Script:ApplyRun.ManifestPath = $null }
            Complete-ApplyRun -Outcome "Complete"
            return
        }

        $id = $Script:ApplyRun.Queue.Dequeue()
        $Script:ApplyRun.Index++
        $pct = [int](($Script:ApplyRun.Index / [double]$Script:ApplyRun.Total) * 100)
        $progress.Value = [Math]::Min(100,[Math]::Max(0,$pct))
        $statusLabel.Text = "Working: $id"

        $t = $Script:Tweaks | Where-Object { $_.Id -eq $id } | Select-Object -First 1
        if (-not $t) { return }

        try {
            & $t.Apply $Script:ApplyRun.BackupCtx $outputBox $statusLabel
            Write-Log -Message ("OK: {0}" -f $t.Name) -OutputBox $outputBox -Color $Script:Colors.Success -StatusLabel $statusLabel
        } catch {
            $Script:ApplyRun.HadErrors = $true
            Write-Log -Message ("ERROR: {0} failed -> {1}" -f $t.Name, $_.Exception.Message) -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel
        }
    } catch { Complete-ApplyRun -Outcome "Error" -ErrorMessage $_.Exception.Message }
})

#------------------------------------------------------------------------------------------------
# 13.5) Uninstall Engine
#------------------------------------------------------------------------------------------------
$Script:UninstallRun = $null
$uninstallTimer      = New-Object System.Windows.Forms.Timer
$uninstallTimer.Interval = 100   # 100ms poll — enough for interactive process watching

function Start-UninstallRun {
    param(
        [Parameter(Mandatory=$true)][pscustomobject[]]$AppsToRemove,
        [bool]$DeepClean = $false
    )

    # Classify each app up front
    $interactiveList = New-Object System.Collections.Generic.List[pscustomobject]
    $silentList      = New-Object System.Collections.Generic.List[pscustomobject]
    foreach ($app in $AppsToRemove) {
        if ((Get-UninstallMode -App $app) -eq 'Silent') { $silentList.Add($app) }
        else { $interactiveList.Add($app) }
    }

    $interactiveQueue = New-Object System.Collections.Generic.Queue[pscustomobject]
    $silentQueue      = New-Object System.Collections.Generic.Queue[pscustomobject]
    foreach ($a in $interactiveList) { $interactiveQueue.Enqueue($a) }
    foreach ($a in $silentList)      { $silentQueue.Enqueue($a) }

    $Script:UninstallRun = [pscustomobject]@{
        Phase            = 'Interactive'   # Interactive | Silent | DeepClean
        InteractiveQueue = $interactiveQueue
        SilentQueue      = $silentQueue
        DeepCleanQueue   = New-Object System.Collections.Generic.Queue[pscustomobject]
        TotalApps        = $AppsToRemove.Count
        TotalProcessed   = 0
        CurrentProcess   = $null
        CurrentApp       = $null
        SucceededApps    = New-Object System.Collections.Generic.List[pscustomobject]
        DoDeepClean      = $DeepClean
        HadErrors        = $false
    }

    Set-UiRunningState -IsRunning $true
    $progress.Value = 0

    Write-Log -Message ("=== Uninstall queued: {0} interactive, {1} silent ===" -f $interactiveList.Count, $silentList.Count) `
              -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel

    if ($interactiveList.Count -eq 0 -and $silentList.Count -gt 0) {
        # Nothing interactive — go straight to silent phase
        Write-Log -Message "All selected apps support silent uninstall — no user interaction required." `
                  -OutputBox $outputBox -Color $Script:Colors.BlueAccent -StatusLabel $statusLabel
        $Script:UninstallRun.Phase = 'Silent'
    }

    $uninstallTimer.Start()
}

function Complete-UninstallRun {
    $uninstallTimer.Stop()
    Set-UiRunningState -IsRunning $false
    $progress.Value = 0
    $ok  = $Script:UninstallRun.SucceededApps.Count
    $tot = $Script:UninstallRun.TotalApps
    Write-Log -Message ("=== Uninstall complete: {0}/{1} succeeded ===" -f $ok, $tot) `
              -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
    $statusLabel.Text = "Uninstall complete"
    $Script:UninstallRun = $null
    Start-Sleep -Milliseconds 800
    Refresh-UninstallList
}

# Helper — update progress bar from current processed count
function Update-UninstallProgress {
    if (-not $Script:UninstallRun) { return }
    $pct = if ($Script:UninstallRun.TotalApps -gt 0) {
        [int](($Script:UninstallRun.TotalProcessed / [double]$Script:UninstallRun.TotalApps) * 100)
    } else { 0 }
    $progress.Value = [Math]::Min(100, [Math]::Max(0, $pct))
}

$uninstallTimer.Add_Tick({
    try {
        if (-not $Script:UninstallRun) { $uninstallTimer.Stop(); return }

        # ── If a process is currently running, poll it ──────────────────────────
        if ($null -ne $Script:UninstallRun.CurrentProcess) {
            $proc = $Script:UninstallRun.CurrentProcess
            if (-not $proc.HasExited) { return }   # still running — come back next tick

            # Process has finished
            $exitCode = $proc.ExitCode
            $app      = $Script:UninstallRun.CurrentApp
            $isSilent = ($Script:UninstallRun.Phase -eq 'Silent')
            $success  = ($exitCode -in 0, 3010, 1605)

            $exitColor = if ($success) { $Script:Colors.Success } else { $Script:Colors.Danger }
            Write-Log -Message "  Exit code: $exitCode" -OutputBox $outputBox -Color $exitColor -StatusLabel $statusLabel

            if ($success) {
                [void]$Script:UninstallRun.SucceededApps.Add($app)
            } else {
                $Script:UninstallRun.HadErrors = $true
                Write-Log -Message "  WARNING: $($app.DisplayName) may not have uninstalled cleanly (exit $exitCode)." `
                          -OutputBox $outputBox -Color $Script:Colors.Warning -StatusLabel $statusLabel
            }

            $Script:UninstallRun.TotalProcessed++
            $Script:UninstallRun.CurrentProcess = $null
            $Script:UninstallRun.CurrentApp      = $null
            Update-UninstallProgress
            return   # let the next tick start the next app
        }

        # ── No active process — advance the state machine ───────────────────────

        switch ($Script:UninstallRun.Phase) {

            'Interactive' {
                if ($Script:UninstallRun.InteractiveQueue.Count -gt 0) {
                    $app = $Script:UninstallRun.InteractiveQueue.Dequeue()
                    $statusLabel.Text = "Waiting for user: $($app.DisplayName)"
                    $proc = Start-UninstallProcess -App $app -Silent $false -OutputBox $outputBox -StatusLabel $statusLabel
                    if ($null -ne $proc) {
                        $Script:UninstallRun.CurrentProcess = $proc
                        $Script:UninstallRun.CurrentApp     = $app
                    } else {
                        # Failed to start — count as processed, mark error
                        $Script:UninstallRun.TotalProcessed++
                        $Script:UninstallRun.HadErrors = $true
                        Update-UninstallProgress
                    }
                } else {
                    # Interactive queue drained — move to Silent
                    if ($Script:UninstallRun.SilentQueue.Count -gt 0) {
                        $n = $Script:UninstallRun.SilentQueue.Count
                        Write-Log -Message ("--- {0} app{1} will now uninstall silently (no prompts) ---" -f $n, $(if($n -ne 1){'s'}else{''})) `
                                  -OutputBox $outputBox -Color $Script:Colors.BlueAccent -StatusLabel $statusLabel
                        $Script:UninstallRun.Phase = 'Silent'
                    } elseif ($Script:UninstallRun.DoDeepClean -and $Script:UninstallRun.SucceededApps.Count -gt 0) {
                        foreach ($a in $Script:UninstallRun.SucceededApps) { $Script:UninstallRun.DeepCleanQueue.Enqueue($a) }
                        Write-Log -Message "--- Deep clean pass: scanning for leftover files and registry keys ---" `
                                  -OutputBox $outputBox -Color $Script:Colors.BlueAccent -StatusLabel $statusLabel
                        $Script:UninstallRun.Phase = 'DeepClean'
                    } else {
                        Complete-UninstallRun
                    }
                }
            }

            'Silent' {
                if ($Script:UninstallRun.SilentQueue.Count -gt 0) {
                    $app = $Script:UninstallRun.SilentQueue.Dequeue()
                    $statusLabel.Text = "Uninstalling (silent): $($app.DisplayName)"
                    $proc = Start-UninstallProcess -App $app -Silent $true -OutputBox $outputBox -StatusLabel $statusLabel
                    if ($null -ne $proc) {
                        $Script:UninstallRun.CurrentProcess = $proc
                        $Script:UninstallRun.CurrentApp     = $app
                    } else {
                        $Script:UninstallRun.TotalProcessed++
                        $Script:UninstallRun.HadErrors = $true
                        Update-UninstallProgress
                    }
                } else {
                    # Silent queue drained
                    if ($Script:UninstallRun.DoDeepClean -and $Script:UninstallRun.SucceededApps.Count -gt 0) {
                        foreach ($a in $Script:UninstallRun.SucceededApps) { $Script:UninstallRun.DeepCleanQueue.Enqueue($a) }
                        Write-Log -Message "--- Deep clean pass: scanning for leftover files and registry keys ---" `
                                  -OutputBox $outputBox -Color $Script:Colors.BlueAccent -StatusLabel $statusLabel
                        $Script:UninstallRun.Phase = 'DeepClean'
                    } else {
                        Complete-UninstallRun
                    }
                }
            }

            'DeepClean' {
                if ($Script:UninstallRun.DeepCleanQueue.Count -gt 0) {
                    $app = $Script:UninstallRun.DeepCleanQueue.Dequeue()
                    $statusLabel.Text = "Deep clean: $($app.DisplayName)"
                    try { Invoke-DeepClean -App $app -OutputBox $outputBox -StatusLabel $statusLabel }
                    catch { Write-Log -Message "  Deep clean error for $($app.DisplayName): $($_.Exception.Message)" -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel }
                } else {
                    Complete-UninstallRun
                }
            }
        }

    } catch {
        $uninstallTimer.Stop()
        Set-UiRunningState -IsRunning $false
        Write-Log -Message "Uninstall engine fatal error: $($_.Exception.Message)" -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel
    }
})

