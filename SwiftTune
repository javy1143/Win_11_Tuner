                Write-Log -Message "SKIPPED (safelisted): $($s.Name)" -OutputBox $OutputBox -Color $Script:Colors.Warning -StatusLabel $StatusLabel
                continue
            }
            try { Set-ServiceStartup -BackupCtx $BackupCtx -Name $s.Name -StartupType $s.Startup -OutputBox $OutputBox -StatusLabel $StatusLabel }
