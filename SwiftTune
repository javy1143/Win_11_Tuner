# 12) State Refresh
#------------------------------------------------------------------------------------------------
function Refresh-TweakStates {
    foreach ($t in $Script:Tweaks) {
        $state = "Unknown"
        try {
            if (-not (& $t.IsAvailable)) { $state = "NotAvailable" }
            else { $state = & $t.GetState }
        } catch { $state = "Unknown" }

        $lbl = $Script:StateLabels[$t.Id]
        if ($lbl) {
            $lbl.Text = $state
            $lbl.ForeColor = switch ($state) {
                "Applied"      { $Script:Colors.Success }
                "NotApplied"   { $Script:Colors.TextMuted }
                "Partial"      { $Script:Colors.Warning }
                "NotAvailable" { [System.Drawing.Color]::Gray }
                "N-A"          { [System.Drawing.Color]::Gray }
                default        { [System.Drawing.Color]::Orange }
            }
        }

        $cb = $Script:CheckBoxes[$t.Id]
        if ($cb) { $cb.Enabled = (& $t.IsAvailable) }
    }
}

