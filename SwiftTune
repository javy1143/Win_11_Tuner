# 12.5) Uninstaller List Population
#------------------------------------------------------------------------------------------------
function Populate-UninstallList {
    param([string]$Filter = "")
    $uninstListView.BeginUpdate()
    $uninstListView.Items.Clear()

    $source = $Script:AllInstalledApps
    if ($Filter.Trim().Length -gt 0) {
        $f = $Filter.Trim()
        $source = @($source | Where-Object {
            $_.DisplayName -like "*$f*" -or $_.Publisher -like "*$f*"
        })
    }

    foreach ($app in $source) {
        $item = New-Object System.Windows.Forms.ListViewItem($app.DisplayName)
        [void]$item.SubItems.Add($app.Publisher)
        [void]$item.SubItems.Add($app.Version)
        [void]$item.SubItems.Add($app.InstallDate)
        [void]$item.SubItems.Add($app.SizeStr)
        $item.Tag = $app
        [void]$uninstListView.Items.Add($item)
    }

    $uninstListView.EndUpdate()
    $total = $source.Count
    $lblAppCount.Text = if ($total -eq 0) { "No apps found" } else { "$total app$(if($total -ne 1){'s'})" }
    $lblSelectedCount.Text = "0 selected"
}

function Refresh-UninstallList {
    $btnUninstRefresh.Enabled   = $false
    $btnUninstallSelected.Enabled = $false
    $statusLabel.Text = "Loading installed applications..."
    [System.Windows.Forms.Application]::DoEvents()

    try {
        $Script:AllInstalledApps = @(Get-InstalledApps)
        # Log per-hive diagnostics so scan issues are visible in the output pane
        Write-Log -Message "--- Uninstaller scan ---" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
        foreach ($kv in $Script:UninstDiag.HiveCounts.GetEnumerator()) {
            Write-Log -Message "  Hive [$($kv.Key)]: $($kv.Value)" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
        }
        Write-Log -Message "  Total added=$($Script:UninstDiag.Added) skipped=$($Script:UninstDiag.Skipped)" -OutputBox $outputBox -Color $Script:Colors.TextMuted -StatusLabel $statusLabel
        Populate-UninstallList -Filter $txtSearch.Text
        Write-Log -Message "Uninstaller: $($Script:AllInstalledApps.Count) applications loaded." -OutputBox $outputBox -Color $Script:Colors.BlueAccent -StatusLabel $statusLabel
    } catch {
        Write-Log -Message "Uninstaller: scan exception — $($_.Exception.Message)" -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel
        Write-Log -Message "  $($_.ScriptStackTrace)" -OutputBox $outputBox -Color $Script:Colors.Danger -StatusLabel $statusLabel
    } finally {
        $btnUninstRefresh.Enabled     = $true
        $btnUninstallSelected.Enabled = $true
        $statusLabel.Text = "Ready"
    }
}

